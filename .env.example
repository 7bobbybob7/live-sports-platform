# Copy to .env.local and fill in. .env.local is gitignored.

# Postgres (matches docker-compose.yml defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sports
POSTGRES_PASSWORD=sports
POSTGRES_DB=sports_platform
DATABASE_URL=postgresql://sports:sports@localhost:5432/sports_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Kafka (Redpanda; Kafka wire protocol on :9092)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=live-sports-platform
KAFKA_GROUP_PERSISTENCE=persistence-consumer
KAFKA_TOPIC_MLB_RAW=mlb.events.raw
KAFKA_TOPIC_MLB_RAW_DLQ=mlb.events.raw.dlq

# MLB Stats API (no key required — public)
MLB_STATS_API_BASE=https://statsapi.mlb.com/api/v1
MLB_POLL_INTERVAL_SECONDS=5
MLB_SCHEDULE_POLL_INTERVAL_SECONDS=60

# Query API
QUERY_API_HOST=0.0.0.0
QUERY_API_PORT=8080

# Observability
LOG_LEVEL=INFO
METRICS_PORT_INGESTOR=9100
METRICS_PORT_QUERY_API=9101
METRICS_PORT_PERSISTENCE_CONSUMER=9102

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
